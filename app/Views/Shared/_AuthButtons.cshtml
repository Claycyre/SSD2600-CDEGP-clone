@using Microsoft.AspNetCore.Identity
@using SSD2600_CDEGP.TagHelpers.PaButton;
@inject SignInManager<ApplicationUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    <PaButton
        asp-controller="Messages"
        asp-action="Index"
        Style="PaButtonTagHelper.Styles.Outline"
        Size="PaButtonTagHelper.Sizes.Small"
        Classes="text-slate-600 font-medium"
        Attributes="data-loading-overlay">
        Inbox
    </PaButton>
    <div class="relative">
    </div>
    <details class="relative z-50">
        <summary class="list-none cursor-pointer px-3 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-colors">
            <div>
                <p class="text-xs text-neutral-500 font-semibold">Logged in as</p>
                <p class="">@User.Identity.Name</p>
            </div>
        </summary>
        <div class="absolute right-0 mt-2 w-fit max-w-96 min-w-56 rounded-xl border border-neutral-200 bg-white p-3 shadow-xl">
            <div class="flex flex-col divide-y divide-neutral-500 *:py-2 *:first:pt-0 *:last:pb-0">
                @if (User.IsInRole("Admin")) {
                    <div class="flex flex-col gap-1">
                        <PaButton
                            asp-area=""
                            asp-controller="Admin"
                            asp-action="Index"
                            Style="PaButtonTagHelper.Styles.Fill"
                            Size="PaButtonTagHelper.Sizes.Small"
                            Classes="flex items-center justify-start w-full text-start shadow-lg"
                            Attributes="data-loading-overlay">
                            &#9881; User Admin
                        </PaButton>
                        <PaButton
                            asp-area=""
                            asp-controller="Admin"
                            asp-action="Products"
                            Style="PaButtonTagHelper.Styles.Fill"
                            Size="PaButtonTagHelper.Sizes.Small"
                            Classes="flex items-center justify-start w-full text-start shadow-lg"
                            Attributes="data-loading-overlay">
                            &#9881; Products
                        </PaButton>
                    </div>
                }
                @if (User.IsInRole("Supplier")) {
                    <div class="flex flex-col gap-1">
                        <PaButton
                            asp-controller="Supplier"
                            asp-action="Index"
                            Style="PaButtonTagHelper.Styles.Fill"
                            Size="PaButtonTagHelper.Sizes.Small"
                            Classes="w-full text-start shadow-lg"
                            Attributes="data-loading-overlay">
                            Manage Products
                        </PaButton>
                    </div>
                }
                <div class="flex flex-col gap-1">
                    <PaButton 
                        asp-area="Identity"
                        asp-page="/Account/Manage/Index"
                        Style="PaButtonTagHelper.Styles.Outline"
                        Size="PaButtonTagHelper.Sizes.Small"
                        Classes="text-start">
                        Account
                    </PaButton>
                    <form asp-area="Identity" asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <PaButton 
                            tag="button"
                            Attributes="type=submit"
                            Theme="PaButtonTagHelper.Themes.Danger"
                            Style="PaButtonTagHelper.Styles.Outline"
                            Size="PaButtonTagHelper.Sizes.Small"
                            Classes="block w-full text-start"
                        >
                            Log out
                        </PaButton>
                    </form>
                </div>
            </div>
        </div>
    </details>
}
else
{
    <div class="flex items-center gap-2">
        <PaButton
            asp-area="Identity"
            asp-page="/Account/Register"
            Style="PaButtonTagHelper.Styles.Outline"
            Size="PaButtonTagHelper.Sizes.Small">
            Register
        </PaButton>
        <PaButton
            asp-area="Identity"
            asp-page="/Account/Login"
            Style="PaButtonTagHelper.Styles.Outline"
            Size="PaButtonTagHelper.Sizes.Small">
            Log in
        </PaButton>
    </div>
}
