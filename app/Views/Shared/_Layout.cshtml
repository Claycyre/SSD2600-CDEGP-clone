<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href="~/dist/site.css" asp-append-version="true" />
    
    @*allow for use of partial stylesheets - this is compiled at runtime*@
    <link rel="stylesheet" href="~/SSD2600_CDEGP.styles.css" asp-append-version="true" />

    <title>@ViewData["Title"] - Prometheus Atomics</title>

    <style>
            .nav__list {
                --hover-transition: 200ms ease-in-out;
                gap: 0.5rem;
            }

            .nav__list>li>a {
                position: relative;
                padding: 0.5rem 1rem;
            }

            .nav__list>li>a::after {
                position: absolute;
                content: "";
                bottom: 0;
                left: 50%;
                width: 75%;
                height: 2px;
                background-color: var(--color-primary-500);
                opacity: 0;
                translate: -50% 0;
                transition: opacity var(--hover-transition);
                pointer-events: none;
            }

            .nav__list>li>a:hover::after {
                opacity: 100%;
                transition: none;
            }
    </style>
</head>

<body class="flex min-h-dvh flex-col">
    <header id="site-header" class="shrink border-b border-primary-500 px-2 py-4 shadow-xl">
        <nav class="flex gap-2 lg:gap-8">
            <a class="basis-0" href="/">
                @await Html.PartialAsync("_LogoType", new ViewDataDictionary(ViewData) { { "Size", "small" }, {
                "LogoTypeShouldHide", true } })
            </a>
            <div class="flex grow basis-0 items-center justify-between">
                <ul class="nav__list flex">
                    <li>
                        <a href="/">Home</a>
                    </li>
                    <li>
						<a data-loading-overlay asp-controller="ProductCatalogue" asp-action="Index">Catalogue</a>
                    </li>
                    <li>
                        <a href="#">Placeholder</a>
                    </li>
                </ul>
                <div class="flex items-center gap-2 ml-4">
                    @await Html.PartialAsync("_AuthButtons")
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="grow basis-0">
        @RenderBody()
    </main>

    <!-- Page loading overlay — shown when navigating to slow/deferred pages -->
    <div id="page-loading-overlay"
         class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40">
        <div id="loading-card"
             class="bg-white rounded-2xl shadow-2xl p-8 max-w-sm w-full text-center transition-colors">
            <div id="loading-spinner"
                 class="mx-auto mb-4 h-12 w-12 animate-spin rounded-full border-4 border-slate-200 border-t-slate-600"></div>
            <p id="loading-message" class="text-gray-700 font-semibold">Loading, please wait…</p>
            <p id="loading-subtext" class="mt-1 text-sm text-gray-500">This may take a moment.</p>
        </div>
    </div>

    <footer class="shrink bg-neutral-50 px-2 py-4 shadow-lg">
        <div class="container mx-auto max-w-240">
            <nav class="flex px-6">
                <div class="hidden shrink basis-1/4 md:block">
                </div>
                <ul class="grid shrink-0 grow grid-cols-2 gap-x-2">
                    <li>
                        <a class="footer__link" href="/">Home</a>
                    </li>
                    <li>
                        <a class="footer__link" href="#">Products</a>
                    </li>
                    <li>
                        <a class="footer__link" href="#">About Prometheus Atomics</a>
                    </li>
                    <li>
                        <a class="footer__link" href="#">Contact us</a>
                    </li>
                    <li>
                        <a class="footer__link" href="#">Legal</a>
                    </li>
                    <li>
                        <a class="footer__link" href="#">Privacy</a>
                    </li>
                    <li>
                        <a class="footer__link" href="#">Terms of use</a>
                    </li>
                </ul>
            </nav>
            <div class="text-center">
                <p class="footer__notice">&copy; <span id="copyright-year"></span> - Prometheus Atomics Procurement
                    Industries</p>
                </div>
            </div>
        </footer>
        @await RenderSectionAsync("Scripts", required: false)

        <script defer>
                const copyrightEl = document.getElementById("copyright-year");
                copyrightEl.innerText = new Date().getFullYear()
        </script>
        <script defer>
                const header = document.getElementById('site-header');

                function setHeaderHeight() {
                    const h = header.getBoundingClientRect().height;
                    document.documentElement.style.setProperty('--header-height', `${h}px`);
                }

                setHeaderHeight();
                window.addEventListener('resize', setHeaderHeight);

                // Optional: catches content/font changes too
                new ResizeObserver(setHeaderHeight).observe(header);
        </script>
        <script defer src="~/dist/js/index.js"></script>

        <script>
            // Loading overlay for navigation links tagged with [data-loading-overlay]
            (function () {
                var overlay = null;
                var timeoutId = null;
                var TIMEOUT_MS = 30000;

                function showOverlay() {
                    overlay = document.getElementById('page-loading-overlay');
                    if (!overlay) return;
                    var card = document.getElementById('loading-card');
                    var spinner = document.getElementById('loading-spinner');
                    var msg = document.getElementById('loading-message');
                    var sub = document.getElementById('loading-subtext');

                    // Reset to loading state
                    card.classList.remove('bg-red-50');
                    card.classList.add('bg-white');
                    spinner.classList.remove('hidden', 'border-t-red-500');
                    spinner.classList.add('border-t-slate-600', 'animate-spin');
                    msg.textContent = 'Loading, please wait\u2026';
                    msg.classList.remove('text-red-700');
                    msg.classList.add('text-gray-700');
                    sub.textContent = 'This may take a moment.';
                    overlay.classList.remove('hidden');

                    // 30-second timeout → show error state
                    timeoutId = setTimeout(function () {
                        card.classList.remove('bg-white');
                        card.classList.add('bg-red-50');
                        spinner.classList.add('hidden');
                        msg.classList.remove('text-gray-700');
                        msg.classList.add('text-red-700');
                        msg.textContent = 'Could not reach the requested page.';
                        sub.textContent = 'The server did not respond within 30 seconds. Please try again.';
                    }, TIMEOUT_MS);
                }

                document.addEventListener('DOMContentLoaded', function () {
                    document.querySelectorAll('[data-loading-overlay]').forEach(function (link) {
                        link.addEventListener('click', function (e) {
                            // Only intercept plain left-clicks (not ctrl/cmd/shift)
                            if (!e.ctrlKey && !e.metaKey && !e.shiftKey && e.button === 0) {
                                showOverlay();
                            }
                        });
                    });
                });

                // Dismiss overlay when page actually finishes loading (navigation complete)
                window.addEventListener('pageshow', function () {
                    if (overlay) {
                        overlay.classList.add('hidden');
                    }
                    if (timeoutId) {
                        clearTimeout(timeoutId);
                        timeoutId = null;
                    }
                });
            })();
        </script>
    </body>

</html>
