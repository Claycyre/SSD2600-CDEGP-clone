@model object

@*_FilterCheckboxes.cshtml — handles IndexModel (element phases) and ProductCatalogueIndexViewModel (state of matter)*@
@{
    var catalogueModel = Model as SSD2600_CDEGP.Models.ProductCatalogueIndexViewModel;
    var indexModel = Model as SSD2600_CDEGP.Models.IndexModel;
}

@if (indexModel != null)
{
    <fieldset>
        <legend class="mb-1">Filters</legend>
        <div class="flex flex-col gap-1">
            <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" id="checkboxSolids" name="Phases" value="Solid"
                @(indexModel.Phases.Contains("Solid") ? "checked" : "")
                       onchange="document.getElementById('filterForm').submit()" />
                Solids
            </label>
            <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" id="checkboxLiquids" name="Phases" value="Liquid"
                @(indexModel.Phases.Contains("Liquid") ? "checked" : "")
                       onchange="document.getElementById('filterForm').submit()" />
                Liquids
            </label>
            <label class="flex items-center gap-2 text-sm">
                <input type="checkbox" id="checkboxGases" name="Phases" value="Gas"
                @(indexModel.Phases.Contains("Gas") ? "checked" : "")
                       onchange="document.getElementById('filterForm').submit()" />
                Gases
            </label>
        </div>
    </fieldset>
}
else if (catalogueModel != null)
{
    <fieldset>
        <legend class="font-semibold mb-1">State of Matter</legend>
        <div class="flex flex-col gap-1">
            @foreach (var state in new[] { "Solid", "Liquid", "Gas" })
            {
                <label class="flex items-center gap-2 text-sm">
                    <input type="checkbox" name="states" value="@state"
                    @(catalogueModel.SelectedStates.Contains(state) ? "checked" : "")
                           onchange="this.form.submit()" />
                    @state
                </label>
            }
        </div>
    </fieldset>
}
