@model IndexModel

@*_SortOptions.cshtml*@
<fieldset>
    <legend>Sort</legend>
    <div class="flex flex-col gap-1">
        <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="SortBy" value="" @(string.IsNullOrEmpty(Model.SortBy) ? "checked" : "") onchange="document.getElementById('filterForm').requestSubmit()" />
            Atomic Number
        </label>
        <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="SortBy" value="name" @(Model.SortBy == "name" ? "checked" : "")
                   onchange="document.getElementById('filterForm').requestSubmit()" />
            Name
        </label>
        <label class="flex items-center gap-2 text-sm">
            <input type="radio" name="SortBy" value="mass" @(Model.SortBy == "mass" ? "checked" : "")
                   onchange="document.getElementById('filterForm').requestSubmit()" />
            Atomic Mass
        </label>
    </div>
</fieldset>
