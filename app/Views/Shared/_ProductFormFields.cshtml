@model SSD2600_CDEGP.Models.ProductAddOrEditViewModel

<div class="grid grid-cols-2 gap-6">

    <div class="col-span-2">
        <label asp-for="Name" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="Name" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="Name" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="ShortName" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="ShortName" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="ShortName" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="AtomicNumber" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="AtomicNumber" type="number" class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="AtomicNumber" class="text-red-600 text-xs"></span>
    </div>

    <div class="col-span-2">
        <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <textarea asp-for="Description" rows="3"
                  class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
        <span asp-validation-for="Description" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="UnitPrice" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="UnitPrice" type="number" step="0.01"
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="UnitPrice" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="StockQuantity" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="StockQuantity" type="number"
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="StockQuantity" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="ProductType" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <select asp-for="ProductType"
                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">-- Select --</option>
            <option value="Medical">Medical</option>
            <option value="Industrial">Industrial</option>
            <option value="Research">Research</option>
        </select>
        <span asp-validation-for="ProductType" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="ProductSubtype" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="ProductSubtype"
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="ProductSubtype" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="StateOfMatter" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <select asp-for="StateOfMatter"
                class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">-- Select --</option>
            <option value="Solid">Solid</option>
            <option value="Liquid">Liquid</option>
            <option value="Gas">Gas</option>
        </select>
        <span asp-validation-for="StateOfMatter" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="HalfLife" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="HalfLife"
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="HalfLife" class="text-red-600 text-xs"></span>
    </div>

    <div>
        <label asp-for="Purity" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="Purity"
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="Purity" class="text-red-600 text-xs"></span>
    </div>

    <div class="col-span-2">
        <label asp-for="SpecificActivity" class="block text-sm font-medium text-gray-700 mb-1"></label>
        <input asp-for="SpecificActivity"
               class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500" />
        <span asp-validation-for="SpecificActivity" class="text-red-600 text-xs"></span>
    </div>

</div>
