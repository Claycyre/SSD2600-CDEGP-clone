@model SSD2600_CDEGP.Models.CartViewModel

<div class="w-full max-w-md bg-white border rounded-lg shadow p-4">
    <h3 class="text-lg font-semibold mb-3">Shopping Cart (@Model.ItemCount)</h3>

    @if (Model.Items == null || !Model.Items.Any())
    {
        <div class="text-sm text-gray-500">Your cart is empty.</div>
    }
    else
    {
        <ul class="space-y-3">
            @foreach (var item in Model.Items)
            {
                <li class="flex items-center gap-3 border rounded p-2">
                    <div class="w-12 h-12 bg-gray-100 rounded flex items-center justify-center overflow-hidden">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="text-sm text-gray-600">Img</span>
                        }
                    </div>
                    <div class="flex-1">
                        <div class="font-medium">@item.Name</div>
                        <div class="text-sm text-gray-500">@item.Quantity x @item.Price.ToString("C")</div>
                    </div>
                    <div class="text-right">
                        <div class="font-semibold">@item.LineTotal.ToString("C")</div>
                        <form method="post" asp-controller="Cart" asp-action="Remove" class="mt-1">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="text-xs text-red-600 hover:underline">Remove</button>
                        </form>
                    </div>
                </li>
            }
        </ul>

        <div class="mt-4 border-t pt-3 flex items-center justify-between">
            <div class="font-semibold">Total</div>
            <div class="font-bold">@Model.Total.ToString("C")</div>
        </div>

        <div class="mt-4">
            <a asp-controller="Checkout" asp-action="Index"
               class="block w-full bg-blue-600 text-white rounded px-4 py-2 text-center">
                Checkout
            </a>
        </div>
    }
</div>
