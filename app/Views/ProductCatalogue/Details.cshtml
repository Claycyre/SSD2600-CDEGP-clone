@using SSD2600_CDEGP.Helpers;
@model SSD2600_CDEGP.Models.ProductViewModel
@{
    ViewData["Title"] = Model?.Name ?? "Product Details";
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10 max-w-4xl mx-auto">
            <div class="grid grid-cols-3 gap-6">
                <div class="col-span-1">
                    <div class="w-full h-48 bg-gray-200 rounded flex items-center justify-center">
                        @* img block commented out — no image support.
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover rounded" />
                        }
                        else
                        {
                            <span class="text-gray-500">No image</span>
                        }
                        *@
                        <span class="text-gray-500">No image</span>
                    </div>
                </div>
                <div class="col-span-2">
                    <h1 class="text-2xl font-semibold">@Model.Name</h1>
                    <div class="flex gap-2 mt-1">
                        <span class="text-xs text-white bg-blue-500 rounded-full px-2 py-0.5">@Model.ProductType</span>
                        @if (!string.IsNullOrEmpty(Model.ProductSubtype))
                        {
                            <span class="text-xs text-white bg-blue-400 rounded-full px-2 py-0.5">@Model.ProductSubtype</span>
                        }
                        <span class="text-xs text-white bg-gray-500 rounded-full px-2 py-0.5">@Model.StateOfMatter</span>
                    </div>
                    <p class="text-gray-600 mt-3">@Model.Description</p>

                    <!-- Specifications table -->
                    <div class="mt-4 overflow-hidden rounded-lg border border-gray-200">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-gray-50 border-b border-gray-200">
                                    <th class="px-4 py-2 text-left font-semibold text-gray-600 w-1/2">Specification</th>
                                    <th class="px-4 py-2 text-left font-semibold text-gray-600">Value</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                <tr>
                                    <td class="px-4 py-2 text-gray-500">Type</td>
                                    <td class="px-4 py-2">
                                        @Model.ProductType@(!string.IsNullOrEmpty(Model.ProductSubtype) ? " – " + Model.ProductSubtype : "")
                                    </td>
                                </tr>
                                <tr>
                                    <td class="px-4 py-2 text-gray-500">State of Matter</td>
                                    <td class="px-4 py-2">@Model.StateOfMatter</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(Model.HalfLife))
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-gray-500">Half-Life</td>
                                        <td class="px-4 py-2">@Model.HalfLife</td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.Purity))
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-gray-500">Purity</td>
                                        <td class="px-4 py-2">@Model.Purity</td>
                                    </tr>
                                }
                                @if (!string.IsNullOrEmpty(Model.SpecificActivity))
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-gray-500">Specific Activity</td>
                                        <td class="px-4 py-2">@Model.SpecificActivity</td>
                                    </tr>
                                }
                                <tr>
                                    <td class="px-4 py-2 text-gray-500">Price per gram</td>
                                    <td class="px-4 py-2 font-semibold">@PriceUtils.FormatPerGram((double)Model.Price, Model.CurrencyCode)</td>
                                </tr>
                                @if (!string.IsNullOrEmpty(Model.SupplierName))
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-gray-500">Supplier</td>
                                        <td class="px-4 py-2">@Model.SupplierName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-6 flex items-center justify-between">
                        <div class="text-lg font-bold">@Model.Price.ToString("C")</div>
                        <form method="post" asp-controller="Cart" asp-action="Add">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="number" name="quantity" value="1" min="1" class="w-20 border rounded px-2 py-1" />
                            <PaButton Attributes="type=submit"
                                Theme="PaButton.Themes.Primary"
                            >Add to Cart</PaButton>
                        </form>
                    </div>

                    <a asp-action="Index" asp-controller="ProductCatalogue" class="inline-block mt-6 text-sm text-blue-600">? Back to catalogue</a>
                </div>
            </div>
        </div>
    </div>
</div>
