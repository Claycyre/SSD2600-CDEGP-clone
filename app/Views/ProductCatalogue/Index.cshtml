@using SSD2600_CDEGP.Helpers
@using SSD2600_CDEGP.Models
@model SSD2600_CDEGP.Models.FilterCatalogueModel
@{
    ViewData["Title"] = "Product Catalogue";

    var sampleCart = new CartViewModel { Items = [] };
}

<div class="p-8">
    <div class="flex gap-6 items-start">

        <!-- LEFT SIDEBAR: filters (like home page) -->
        <div class="shrink-0 w-44 rounded-xl shadow-lg p-4">
            @await Html.PartialAsync("_FilterSidebar", Model, new ViewDataDictionary(ViewData) {{ "LegendClass",
                "font-semibold"}})
        </div>

        <!-- CENTRE: search + product list -->
        <div class="flex-1 space-y-6">
            <!-- Search bar -->
            <form method="get" asp-controller="ProductCatalogue" asp-action="Index">
                <!-- carry filter selections through search submissions -->
                @foreach (var t in Model.SelectedApplications)
                {
                    <input type="hidden" name="ap" value="@t" />
                }
                @foreach (var s in Model.SelectedPhases)
                {
                    <input type="hidden" name="ph" value="@s" />
                }
                <div class="flex gap-2">
                    <input type="text" name="q" value="@Model.Query" placeholder="Search products, e.g. Technetium-99m"
                           class="flex-1 px-2 py-1 border border-gray-300 rounded-lg focus:outline-none focus:ring focus:ring-primary-500" oninput="searchDebounced(event)"/>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.Query))
            {
                <p class="mt-2 text-sm text-gray-500">
                    @Model.Products.Count result@(Model.Products.Count == 1 ? "" : "s") for
                    <span class="font-semibold">"@Model.Query"</span>
                </p>
            }

            <!-- Product List -->
            <div class="flex lg:grid flex-wrap grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-4">
                @if (Model.Products.Count == 0)
                {
                    <p class="text-gray-500 text-center py-10">No products found.</p>
                }
                else
                {
                    @foreach (var product in Model.Products)
                    {
                        <div class="basis-full lg:min-h-56">
                            <a asp-controller="ProductCatalogue" asp-action="Details" asp-route-id="@product.PkSKU" class="block h-full border rounded-xl p-4 bg-gray-50 shadow hover:shadow-md transition">
                                <div class="flex flex-col justify-between h-[inherit]">
                                    <div class="flex flex-col flex-wrap">
                                        <div class="flex flex-wrap justify-between">
                                            <span class="font-medium">@product.Name</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(product.ShortName))
                                        {
                                            <span class="text-sm text-gray-500">(@product.ShortName)</span>
                                        }
                                    </div>
                                    <div class="flex flex-col items-end gap-x-4">
                                        <div>
                                            <span title="@product.ProductType"
                                            class="w-fit text-xs text-white bg-blue-500 rounded-full px-2 py-0.5 whitespace-normal">@BadgeUtils.ProductTypeAbbrev(product.ProductType)</span>
                                            <span title="@product.StateOfMatter"
                                            class="w-fit text-xs text-white bg-gray-500 rounded-full px-2 py-0.5">@BadgeUtils.StateOfMatterAbbrev(product.StateOfMatter)</span>
                                        </div>
                                        <span class="text-lg text-black font-semibold">@PriceUtils.Format(product.UnitPrice)<span class="text-sm text-gray-700 font-medium">/g</span></span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                }
            </div>

        </div>

            <!-- RIGHT PANEL: past purchases + shopping cart -->
            <div class="col-span-1 flex flex-col gap-6">
                <div class="w-full flex flex-col gap-6">

                    <!-- Shopping Cart partial -->
                    <div>
                        @await Html.PartialAsync("_ShoppingCart", sampleCart)
                    </div>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Past Purchases -->
                        <div class="border rounded-xl p-6 bg-gray-50 shadow-md">
                            <h2 class="font-semibold mb-6 border-b pb-2">Past Purchases</h2>
                            @if (Model.RecentPurchases.Count == 0)
                            {
                                <p class="text-sm text-gray-500">No past purchases yet.</p>
                            }
                            else
                            {
                                <div class="space-y-4">
                                    @foreach (var purchase in Model.RecentPurchases)
                                    {
                                        <a asp-controller="ProductCatalogue" asp-action="Details" asp-route-id="@purchase.Product.PkSKU"
                                               class="flex items-center gap-4 border rounded-lg p-3 bg-white shadow-sm hover:shadow-md transition">
                                            <div
                                                class="w-12 h-12 bg-blue-600 text-white rounded flex items-center justify-center font-bold text-sm shrink-0">
                                                @(purchase.Product.ShortName?.Split('-').FirstOrDefault() ??
                                        purchase.Product.Name.Split(' ').FirstOrDefault() ?? "?")
                                            </div>
                                            <div class="min-w-0">
                                                <p class="text-sm font-medium truncate">@purchase.Product.Name</p>
                                                <p class="text-xs text-gray-500">
                                                    @PriceUtils.FormatPerGram(purchase.PriceAtPurchase, purchase.CurrencyCode)
                                                </p>
                                            </div>
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

@section Scripts {
    <script defer src="~/dist/js/search.js"></script>
}
