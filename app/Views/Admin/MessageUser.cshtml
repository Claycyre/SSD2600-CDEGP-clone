@model SSD2600_CDEGP.Models.ComposeMessageViewModel
@{
    ViewData["Title"] = "Send Message";
}

<div class="mx-auto w-full min-h-[calc(100vh-var(--header-height))] px-6 py-10 lg:px-10">
    <div class="mx-auto w-full max-w-2xl space-y-6">

        <a asp-action="Index" class="text-sm font-semibold text-primary-700 hover:text-primary-600">&#8592; User
            Management</a>

            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Admin</p>
                <h1 class="font-displayxp text-2xl text-primary-900">Send Message to @Model.RecipientName</h1>
                <p class="text-sm text-neutral-600">Compose a direct message to the user.</p>
            </div>

            <form method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RecipientId" />
                <input type="hidden" asp-for="RecipientName" />

                <div class="space-y-2">
                    <label class="block text-sm font-semibold text-neutral-700">To</label>
                    <div class="rounded-md border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm text-neutral-600">
                        @Model.RecipientName
                    </div>
                </div>

                <div class="space-y-2">
                    <label asp-for="Subject" class="block text-sm font-semibold text-neutral-700">Subject</label>
                    <input asp-for="Subject"
                           class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30"
                           placeholder="Message subject" />
                    <span asp-validation-for="Subject" class="text-sm text-beta-600"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="Body" class="block text-sm font-semibold text-neutral-700">Message</label>
                    <textarea asp-for="Body" rows="8"
                              class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30 resize-y"
                              placeholder="Write your message here…"></textarea>
                    <span asp-validation-for="Body" class="text-sm text-beta-600"></span>
                </div>

                <div class="flex flex-wrap gap-3">
                    <PaButton tag="button" Attributes="type=submit" Theme="PaButtonTagHelper.Themes.Primary"
                              Style="PaButtonTagHelper.Styles.Fill" Size="PaButtonTagHelper.Sizes.Base"
                              Classes="inline-flex items-center justify-center text-sm font-semibold shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40">
                        Send Message
                    </PaButton>
                    <PaButton asp-action="Index"
                        Style="PaButtonTagHelper.Styles.Outline"
                    >
                        Cancel
                    </PaButton>
                </div>
            </form>

        </div>
    </div>

    @section Scripts {
        @await Html.PartialAsync("_ValidationScriptsPartial")
    }
