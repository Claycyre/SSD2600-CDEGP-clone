@model SSD2600_CDEGP.Models.ComposeMessageViewModel
@{
    ViewData["Title"] = "Send Message";
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10 max-w-2xl mx-auto">

            <a asp-action="Index" class="text-sm text-slate-600 hover:underline">&#8592; User Management</a>

            <h1 class="text-2xl font-semibold mt-6 mb-8">Send Message to @Model.RecipientName</h1>

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="RecipientId" />
                <input type="hidden" asp-for="RecipientName" />

                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">To</label>
                    <div class="border border-gray-200 rounded-lg px-4 py-3 bg-gray-50 text-sm text-gray-600">
                        @Model.RecipientName
                    </div>
                </div>

                <div class="mb-6">
                    <label asp-for="Subject" class="block text-sm font-semibold text-gray-700 mb-2">Subject</label>
                    <input asp-for="Subject"
                           class="w-full border border-gray-300 rounded-lg px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500"
                           placeholder="Message subject" />
                    <span asp-validation-for="Subject" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-8">
                    <label asp-for="Body" class="block text-sm font-semibold text-gray-700 mb-2">Message</label>
                    <textarea asp-for="Body" rows="8"
                              class="w-full border border-gray-300 rounded-lg px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500 resize-y"
                              placeholder="Write your message here…"></textarea>
                    <span asp-validation-for="Body" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="flex gap-3">
                    <button type="submit"
                            class="px-6 py-3 bg-slate-600 text-white font-semibold rounded-lg hover:bg-slate-500 shadow transition-colors">
                        Send Message
                    </button>
                    <a asp-action="Index"
                       class="px-6 py-3 bg-gray-200 text-gray-700 font-semibold rounded-lg hover:bg-gray-300 transition-colors">
                        Cancel
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
