@model IEnumerable<SSD2600_CDEGP.Models.Product>
@using SSD2600_CDEGP.Helpers
@{
    ViewData["Title"] = "Product Verification";
    var sortBy = ViewBag.SortBy as string;

    string SortLink(string column) =>
        Url.Action("Products", "Admin", new { sortBy = column })!;

    string SortClass(string column) =>
        sortBy == column ? "underline font-bold" : "hover:underline cursor-pointer";
}

<div class="mx-auto w-full min-h-[calc(100vh-var(--header-height))] px-6 py-10 lg:px-10">
    <div class="space-y-8">

        <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Admin</p>
            <h1 class="font-displayxp text-3xl text-primary-900">Product Verification</h1>
            <p class="text-sm text-neutral-600">Approve or reject supplier submissions.</p>
        </div>

            @{
                var pending = Model.Where(p => !p.IsAdminVerified).ToList();
                var verified = Model.Where(p => p.IsAdminVerified).ToList();
            }

            @if (pending.Any())
            {
                <div class="flex items-center gap-2 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                    <span class="font-bold text-xl">&#9888;</span>
                    <span><strong>@pending.Count</strong> product@(pending.Count == 1 ? "" : "s") awaiting verification.</span>
                </div>
            }

            <h2 class="text-lg font-semibold text-neutral-900">Pending Verification</h2>
            @if (!pending.Any())
            {
                <p class="text-neutral-500 text-sm">No products pending verification.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left border-collapse">
                        <thead>
                            <tr class="bg-amber-50 text-neutral-700 uppercase text-xs">
                                <th class="px-4 py-3 border-b"><a href="@SortLink("name")" class="@SortClass("name")">Name</a></th>
                                <th class="px-4 py-3 border-b"><a href="@SortLink("supplier")" class="@SortClass("supplier")">Supplier</a></th>
                                <th class="px-4 py-3 border-b"><a href="@SortLink("type")" class="@SortClass("type")">Type</a></th>
                                <th class="px-4 py-3 border-b">Price</th>
                                <th class="px-4 py-3 border-b">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in pending)
                            {
                                <tr class="border-b hover:bg-neutral-50 transition-colors">
                                    <td class="px-4 py-3">
                                        <div class="font-medium">@product.Name</div>
                                        @if (!string.IsNullOrEmpty(product.ShortName))
                                        {
                                            <div class="text-neutral-500 text-xs">@product.ShortName</div>
                                        }
                                    </td>
                                    <td class="px-4 py-3">@(product.Supplier?.Name ?? "—")</td>
                                    <td class="px-4 py-3">@product.ProductType</td>
                                    <td class="px-4 py-3">@PriceUtils.Format(product.UnitPrice, product.Supplier?.CurrencyCode ?? "CAD")</td>
                                    <td class="px-4 py-3">
                                        <div class="flex gap-2">
                                            <form method="post" asp-action="ApproveProduct" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@product.PkSKU" />
                                                <button type="submit"
                                                        class="text-xs px-3 py-1 rounded-md bg-emerald-600 text-white hover:bg-emerald-700 transition-colors">
                                                    &#10003; Approve
                                                </button>
                                            </form>
                                            <form method="post" asp-action="RejectProduct" class="inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="productId" value="@product.PkSKU" />
                                                <button type="submit"
                                                        class="text-xs px-3 py-1 rounded-md bg-rose-600 text-white hover:bg-rose-700 transition-colors"
                                                        onclick="return confirm('Reject and delete this product?')">
                                                    &#10007; Reject
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            <h2 class="text-lg font-semibold text-neutral-900">Verified Products</h2>
            @if (!verified.Any())
            {
                <p class="text-neutral-500 text-sm">No verified products.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left border-collapse">
                        <thead>
                            <tr class="bg-neutral-50 text-neutral-600 uppercase text-xs">
                                <th class="px-4 py-3 border-b"><a href="@SortLink("name")" class="@SortClass("name")">Name</a></th>
                                <th class="px-4 py-3 border-b"><a href="@SortLink("supplier")" class="@SortClass("supplier")">Supplier</a></th>
                                <th class="px-4 py-3 border-b"><a href="@SortLink("type")" class="@SortClass("type")">Type</a></th>
                                <th class="px-4 py-3 border-b">Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in verified)
                            {
                                <tr class="border-b hover:bg-neutral-50 transition-colors">
                                    <td class="px-4 py-3 font-medium">@product.Name</td>
                                    <td class="px-4 py-3">@(product.Supplier?.Name ?? "—")</td>
                                    <td class="px-4 py-3">@product.ProductType</td>
                                    <td class="px-4 py-3">@PriceUtils.Format(product.UnitPrice, product.Supplier?.CurrencyCode ?? "CAD")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

    </div>
</div>
