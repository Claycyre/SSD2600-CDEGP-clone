@model SSD2600_CDEGP.Models.UserAdminViewModel
@using SSD2600_CDEGP.Helpers
@{
    ViewData["Title"] = "User Management";
}

<div class="mx-auto w-full min-h-[calc(100vh-var(--header-height))] px-6 py-10 lg:px-10">
    <div class="space-y-8">
        <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Admin</p>
            <h1 class="font-displayxp text-3xl text-primary-900">User Management</h1>
            <p class="text-sm text-neutral-600">Manage users, verification, and account status.</p>
        </div>

            @if (TempData["Success"] != null)
            {
                <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-800">
                    @TempData["Success"]
                </div>
            }

            @if (Model.PendingProductCount > 0)
            {
                <div class="flex items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-xl">&#9888;</span>
                        <span>
                            <strong>@Model.PendingProductCount</strong>
                            product@(Model.PendingProductCount == 1 ? "" : "s")
                            awaiting verification.
                        </span>
                    </div>
                    <a asp-action="Products" class="ml-4 text-sm font-semibold text-primary-700 hover:text-primary-600">Review →</a>
                </div>
            }

            @if (Model.PendingVerificationCount > 0)
            {
                <div class="flex items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-xl">&#9888;</span>
                        <span>
                            <strong>@Model.PendingVerificationCount</strong>
                            @(Model.PendingVerificationCount == 1 ? "user is" : "users are")
                            waiting for identity verification review.
                        </span>
                    </div>
                </div>
            }

            <!-- Search -->
            <form method="get" asp-action="Index" class="flex flex-col gap-3 sm:flex-row">
                <input type="text" name="search" value="@Model.SearchQuery"
                       placeholder="Search by ID, email, username, or phone number"
                       class="flex-1 rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30" />
                <button type="submit"
                        class="inline-flex items-center justify-center rounded-md bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40">
                    Search
                </button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <a asp-action="Index" class="inline-flex items-center justify-center rounded-md bg-neutral-100 px-4 py-2 text-sm font-semibold text-neutral-700 hover:bg-neutral-200 transition-colors">Clear</a>
                }
            </form>

            <!-- User Table -->
            @if (Model.Users.Count == 0)
            {
                <p class="text-neutral-500 text-center py-10 text-sm">No users found.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left border-collapse">
                        <thead>
                            <tr class="bg-neutral-50 text-neutral-600 uppercase text-xs">
                                <th class="px-4 py-3 border-b">Username / Email</th>
                                <th class="px-4 py-3 border-b">Account Type</th>
                                <th class="px-4 py-3 border-b">Organization</th>
                                <th class="px-4 py-3 border-b">Currency</th>
                                <th class="px-4 py-3 border-b">Last Transaction</th>
                                <th class="px-4 py-3 border-b">&#10003; Email</th>
                                <th class="px-4 py-3 border-b">Status</th>
                                <th class="px-4 py-3 border-b">Verification</th>
                                <th class="px-4 py-3 border-b">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                var isCurrentUser = user.Id == Model.CurrentUserId;
                                var isSiteAdmin = user.UserRole == "SiteAdmin";
                                var canModerate = !isCurrentUser && !isSiteAdmin;

                                <tr class="border-b hover:bg-neutral-50 transition-colors">
                                    <!-- Username / Email — links to detail page -->
                                    <td class="px-4 py-3">
                                        <a asp-action="User" asp-route-userId="@user.Id" class="hover:underline">
                                            <div class="font-medium text-neutral-900">@(user.UserName ?? "—")</div>
                                            <div class="text-neutral-500 text-xs">@(user.Email ?? "—")</div>
                                        </a>
                                    </td>

                                    <!-- Account Type -->
                                    <td class="px-4 py-3 text-neutral-700">@user.UserRole.GetUserRoleDisplayName()</td>

                                    <!-- Organization -->
                                    <td class="px-4 py-3 text-neutral-700">@(user.Supplier?.Name ?? "—")</td>

                                    <!-- Preferred Currency -->
                                    <td class="px-4 py-3 font-mono text-neutral-700">@user.PreferredCurrencyCode</td>

                                    <!-- Last Transaction -->
                                    <td class="px-4 py-3">
                                        @* @if (recentPurchase != null)
                                        {
                                            <div class="font-medium truncate max-w-[140px]">@(recentPurchase.Product?.Name ?? "—")</div>
                                            <div class="text-xs text-gray-500">@recentPurchase.PurchasedAt.ToString("yyyy-MM-dd")</div>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400 text-xs">—</span>
                                        } *@
                                    </td>

                                    <!-- Email Confirmed -->
                                    <td class="px-4 py-3 text-center">
                                        @if (user.EmailConfirmed)
                                        {
                                            <span class="text-emerald-600 font-bold">&#10003;</span>
                                        }
                                        else
                                        {
                                            <span class="text-rose-600 font-bold">&#10007;</span>
                                        }
                                    </td>

                                    <!-- Status -->
                                    <td class="px-4 py-3">
                                        @if (user.UserBanned)
                                        {
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-rose-100 text-rose-700">Banned</span>
                                        }
                                        else if (user.UserSuspended)
                                        {
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">Suspended</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700">Active</span>
                                        }
                                    </td>

                                    <!-- Verification -->
                                    <td class="px-4 py-3">
                                        @if (user.UserRole == "PrivateCitizen")
                                        {
                                            <span class="text-neutral-400 text-xs">N/A</span>
                                        }
                                        else if (user.VerificationApproved)
                                        {
                                            <span class="text-emerald-600 font-semibold">&#10003; Approved</span>
                                        }
                                        else if (user.VerificationSubmitted)
                                        {
                                            <span class="text-amber-600 font-semibold">&#9888; Pending</span>
                                        }
                                        else
                                        {
                                            <span class="text-neutral-400 text-xs">Not submitted</span>
                                        }
                                    </td>

                                    <!-- Actions -->
                                    <td class="px-4 py-3">
                                        <div class="flex flex-col gap-1 min-w-[90px]">
                                            <a asp-action="User" asp-route-userId="@user.Id"
                                               class="text-xs px-3 py-1 rounded-md bg-neutral-100 text-neutral-700 hover:bg-neutral-200 transition-colors text-center">
                                                View →
                                            </a>

                                            @if (user.VerificationSubmitted && !user.VerificationApproved)
                                            {
                                                <form method="post" asp-action="ApproveVerification">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit"
                                                            class="w-full text-xs px-3 py-1 rounded-md bg-primary-600 text-white hover:bg-primary-700 transition-colors">
                                                        &#10003; Approve
                                                    </button>
                                                </form>
                                            }

                                            @if (canModerate)
                                            {
                                                @if (user.UserBanned)
                                                {
                                                    <form method="post" asp-action="UnbanUser">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@user.Id" />
                                                        <button type="submit"
                                                                class="w-full text-xs px-3 py-1 rounded-md bg-emerald-600 text-white hover:bg-emerald-700 transition-colors">
                                                            &#8629; Unban
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    @if (user.UserSuspended)
                                                    {
                                                        <form method="post" asp-action="LiftHold">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@user.Id" />
                                                            <button type="submit"
                                                                    class="w-full text-xs px-3 py-1 rounded-md bg-emerald-600 text-white hover:bg-emerald-700 transition-colors">
                                                                &#8629; Lift Suspension
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-action="PutOnHold">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@user.Id" />
                                                            <button type="submit"
                                                                    class="w-full text-xs px-3 py-1 rounded-md bg-amber-500 text-white hover:bg-amber-600 transition-colors">
                                                                &#9646;&#9646; Suspend
                                                            </button>
                                                        </form>
                                                    }
                                                    <form method="post" asp-action="BanUser">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@user.Id" />
                                                        <button type="submit"
                                                                onclick="return confirm('Permanently ban this user? They will be immediately locked out.')"
                                                                class="w-full text-xs px-3 py-1 rounded-md bg-rose-600 text-white hover:bg-rose-700 transition-colors">
                                                            &#9940; Ban
                                                        </button>
                                                    </form>
                                                }
                                                <a asp-action="MessageUser" asp-route-userId="@user.Id"
                                                   class="text-xs px-3 py-1 rounded-md bg-neutral-900 text-white hover:bg-neutral-800 transition-colors text-center block">
                                                    &#9993; Message
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

    </div>
</div>
