@model SSD2600_CDEGP.Models.UserAdminViewModel
@using SSD2600_CDEGP.Helpers
@{
    ViewData["Title"] = "User Management";
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10">

            <h1 class="text-3xl font-semibold mb-8">User Management</h1>

            @if (TempData["Success"] != null)
            {
                <div class="mb-4 border border-green-400 bg-green-50 text-green-800 px-4 py-3 rounded-lg">
                    @TempData["Success"]
                </div>
            }

            @if (Model.PendingProductCount > 0)
            {
                <div class="mb-4 flex items-center justify-between border border-yellow-400 bg-yellow-50 text-yellow-800 px-4 py-3 rounded-lg">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-xl">&#9888;</span>
                        <span>
                            <strong>@Model.PendingProductCount</strong>
                            product@(Model.PendingProductCount == 1 ? "" : "s")
                            awaiting verification.
                        </span>
                    </div>
                    <a asp-action="Products" class="ml-4 text-sm text-blue-600 hover:underline">Review →</a>
                </div>
            }

            @if (Model.PendingVerificationCount > 0)
            {
                <div class="mb-6 flex items-center justify-between border border-yellow-400 bg-yellow-50 text-yellow-800 px-4 py-3 rounded-lg">
                    <div class="flex items-center gap-2">
                        <span class="font-bold text-xl">&#9888;</span>
                        <span>
                            <strong>@Model.PendingVerificationCount</strong>
                            @(Model.PendingVerificationCount == 1 ? "user is" : "users are")
                            waiting for identity verification review.
                        </span>
                    </div>
                </div>
            }

            <!-- Search -->
            <form method="get" asp-action="Index" class="mb-8 flex gap-2">
                <input type="text" name="search" value="@Model.SearchQuery"
                       placeholder="Search by ID, email, username, or phone number"
                       class="flex-1 border border-gray-300 rounded-lg px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
                <button type="submit"
                        class="px-6 py-3 bg-slate-600 text-white font-semibold rounded-lg hover:bg-slate-500 shadow transition-colors">
                    Search
                </button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchQuery))
                {
                    <a asp-action="Index" class="px-4 py-3 bg-gray-200 rounded-lg hover:bg-gray-300 transition-colors">Clear</a>
                }
            </form>

            <!-- User Table -->
            @if (Model.Users.Count == 0)
            {
                <p class="text-gray-500 text-center py-10">No users found.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-100 text-gray-700 uppercase text-xs">
                                <th class="px-4 py-3 border-b">Username / Email</th>
                                <th class="px-4 py-3 border-b">Account Type</th>
                                <th class="px-4 py-3 border-b">Organization</th>
                                <th class="px-4 py-3 border-b">Currency</th>
                                <th class="px-4 py-3 border-b">Last Transaction</th>
                                <th class="px-4 py-3 border-b">&#10003; Email</th>
                                <th class="px-4 py-3 border-b">Status</th>
                                <th class="px-4 py-3 border-b">Verification</th>
                                <th class="px-4 py-3 border-b">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users)
                            {
                                var isCurrentUser = user.Id == Model.CurrentUserId;
                                var isSiteAdmin = user.UserRole == "SiteAdmin";
                                var canModerate = !isCurrentUser && !isSiteAdmin;

                                <tr class="border-b hover:bg-gray-50 transition-colors">
                                    <!-- Username / Email — links to detail page -->
                                    <td class="px-4 py-3">
                                        <a asp-action="User" asp-route-userId="@user.Id" class="hover:underline">
                                            <div class="font-medium text-slate-700">@(user.UserName ?? "—")</div>
                                            <div class="text-gray-500 text-xs">@(user.Email ?? "—")</div>
                                        </a>
                                    </td>

                                    <!-- Account Type -->
                                    <td class="px-4 py-3 text-gray-700">@user.UserRole.GetUserRoleDisplayName()</td>

                                    <!-- Organization -->
                                    <td class="px-4 py-3 text-gray-700">@(user.Supplier?.Name ?? "—")</td>

                                    <!-- Preferred Currency -->
                                    <td class="px-4 py-3 font-mono text-gray-700">@user.PreferredCurrencyCode</td>

                                    <!-- Last Transaction -->
                                    <td class="px-4 py-3">
                                        @* @if (recentPurchase != null)
                                        {
                                            <div class="font-medium truncate max-w-[140px]">@(recentPurchase.Product?.Name ?? "—")</div>
                                            <div class="text-xs text-gray-500">@recentPurchase.PurchasedAt.ToString("yyyy-MM-dd")</div>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400 text-xs">—</span>
                                        } *@
                                    </td>

                                    <!-- Email Confirmed -->
                                    <td class="px-4 py-3 text-center">
                                        @if (user.EmailConfirmed)
                                        {
                                            <span class="text-green-600 font-bold">&#10003;</span>
                                        }
                                        else
                                        {
                                            <span class="text-red-500 font-bold">&#10007;</span>
                                        }
                                    </td>

                                    <!-- Status -->
                                    <td class="px-4 py-3">
                                        @if (user.UserBanned)
                                        {
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-red-100 text-red-700">Banned</span>
                                        }
                                        else if (user.UserSuspended)
                                        {
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-amber-100 text-amber-700">Suspended</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-green-100 text-green-700">Active</span>
                                        }
                                    </td>

                                    <!-- Verification -->
                                    <td class="px-4 py-3">
                                        @if (user.UserRole == "PrivateCitizen")
                                        {
                                            <span class="text-gray-400 text-xs">N/A</span>
                                        }
                                        else if (user.VerificationApproved)
                                        {
                                            <span class="text-green-600 font-semibold">&#10003; Approved</span>
                                        }
                                        else if (user.VerificationSubmitted)
                                        {
                                            <span class="text-yellow-600 font-semibold">&#9888; Pending</span>
                                        }
                                        else
                                        {
                                            <span class="text-gray-400 text-xs">Not submitted</span>
                                        }
                                    </td>

                                    <!-- Actions -->
                                    <td class="px-4 py-3">
                                        <div class="flex flex-col gap-1 min-w-[90px]">
                                            <a asp-action="User" asp-route-userId="@user.Id"
                                               class="text-xs px-3 py-1 bg-slate-100 text-slate-700 rounded hover:bg-slate-200 transition-colors text-center">
                                                View →
                                            </a>

                                            @if (user.VerificationSubmitted && !user.VerificationApproved)
                                            {
                                                <form method="post" asp-action="ApproveVerification">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit"
                                                            class="w-full text-xs px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors">
                                                        &#10003; Approve
                                                    </button>
                                                </form>
                                            }

                                            @if (canModerate)
                                            {
                                                @if (user.UserBanned)
                                                {
                                                    <form method="post" asp-action="UnbanUser">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@user.Id" />
                                                        <button type="submit"
                                                                class="w-full text-xs px-3 py-1 bg-green-600 text-white rounded hover:bg-green-700 transition-colors">
                                                            &#8629; Unban
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    @if (user.UserSuspended)
                                                    {
                                                        <form method="post" asp-action="LiftHold">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@user.Id" />
                                                            <button type="submit"
                                                                    class="w-full text-xs px-3 py-1 bg-green-600 text-white rounded hover:bg-green-700 transition-colors">
                                                                &#8629; Lift Suspension
                                                            </button>
                                                        </form>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-action="PutOnHold">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="userId" value="@user.Id" />
                                                            <button type="submit"
                                                                    class="w-full text-xs px-3 py-1 bg-amber-500 text-white rounded hover:bg-amber-600 transition-colors">
                                                                &#9646;&#9646; Suspend
                                                            </button>
                                                        </form>
                                                    }
                                                    <form method="post" asp-action="BanUser">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="userId" value="@user.Id" />
                                                        <button type="submit"
                                                                onclick="return confirm('Permanently ban this user? They will be immediately locked out.')"
                                                                class="w-full text-xs px-3 py-1 bg-red-600 text-white rounded hover:bg-red-700 transition-colors">
                                                            &#9940; Ban
                                                        </button>
                                                    </form>
                                                }
                                                <a asp-action="MessageUser" asp-route-userId="@user.Id"
                                                   class="text-xs px-3 py-1 bg-slate-600 text-white rounded hover:bg-slate-500 transition-colors text-center block">
                                                    &#9993; Message
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>

