@{
    ViewData["Title"] = "Checkout";
}

<div class="min-h-screen bg-gray-100 p-6">
    <div class="mb-6">
        <img src="~/images/banner.jpg" alt="Banner" class="w-full rounded-2xl shadow-md" />
    </div>
    <h1 class="text-3xl font-bold text-center text-blue-900 mb-8">
        Checkout
    </h1>
        <div class="bg-white rounded-2xl shadow p-6 flex flex-col">
            <h2 class="text-xl font-semibold mb-4 text-center">Order Summary</h2>
            <div class="flex justify-between py-2 border-b">
                <span>Book x1</span>
                <span>$10.00</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span>Pen x3</span>
                <span>$6.00</span>
            </div>
            <div class="mt-4 space-y-1">
                <div class="flex justify-between">
                    <span>Subtotal</span>
                    <span>$16.00</span>
                </div>
                <div class="flex justify-between">
                    <span>Tax</span>
                    <span>$1.28</span>
                </div>
                <div class="flex justify-between font-bold text-lg border-t pt-2">
                    <span>Total</span>
                    <span>$17.28</span>
                </div>
            </div>
            <button class="mt-6 w-full bg-blue-600 text-white py-3 rounded-full hover:bg-blue-700">
                Place Order
            </button>
        </div>
    </div>
</div>

