@model SSD2600_CDEGP.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="min-h-screen bg-gray-100 p-6">
    <div class="max-w-5xl mx-auto">
        <h1 class="text-3xl font-bold text-blue-900 mb-8">Checkout</h1>

        <div class="flex gap-6">
            <!-- Left: Shipping info + PayPal button -->
            <div class="flex-1 flex flex-col gap-6">

                <!-- Shipping Address -->
                <div class="bg-white rounded-2xl shadow p-6">
                    <h2 class="text-lg font-semibold mb-4">Shipping Address</h2>
                    @if (Model.ContactDetail != null)
                    {
                        <div class="text-gray-700 space-y-1 text-sm">
                            <p class="font-medium">@Model.ContactDetail.NameFirst @Model.ContactDetail.NameLast</p>
                            <p>@Model.ContactDetail.StreetAddress</p>
                            @if (!string.IsNullOrEmpty(Model.ContactDetail.AdministrativeArea))
                            {
                                <p>@Model.ContactDetail.AdministrativeArea@(!string.IsNullOrEmpty(Model.ContactDetail.PostalCode) ? ", " + Model.ContactDetail.PostalCode : "")</p>
                            }
                            <p>@Model.ContactDetail.CountryCode</p>
                            <p>@Model.ContactDetail.EmailAddress</p>
                            <p>@Model.ContactDetail.PhoneNumber</p>
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-gray-500">
                            No shipping address on file.
                            <a asp-controller="Profile" asp-action="Index" class="text-blue-600 hover:underline">Add one in your profile →</a>
                        </p>
                    }
                </div>

                <!-- PayPal Button -->
                <div class="bg-white rounded-2xl shadow p-6">
                    <h2 class="text-lg font-semibold mb-2">Payment</h2>
                    <p class="text-sm text-gray-500 mb-4">Pay securely with PayPal. You will be prompted to log in to your PayPal account.</p>
                    <div id="paypal-button-container"></div>
                    <div id="paypal-error" class="mt-3 text-red-600 text-sm hidden"></div>
                </div>

            </div>

            <!-- Right: Order Summary -->
            <div class="w-72 shrink-0">
                <div class="bg-white rounded-2xl shadow p-6 sticky top-6">
                    <h2 class="text-lg font-semibold mb-4">Order Summary</h2>
                    <div class="space-y-2 text-sm">
                        @foreach (var item in Model.Cart.Items)
                        {
                            <div class="flex justify-between">
                                <span class="text-gray-700">@item.Name <span class="text-gray-400">x@(item.Quantity)</span></span>
                                <span>@item.LineTotal.ToString("C")</span>
                            </div>
                        }
                    </div>
                    <div class="border-t border-gray-200 mt-4 pt-4 flex justify-between font-bold">
                        <span>Total</span>
                        <span>@Model.Cart.Total.ToString("C") @Model.CurrencyCode</span>
                    </div>
                    <a asp-controller="Cart" asp-action="Index"
                       class="block text-center text-sm text-blue-600 mt-4 hover:underline">
                        ← Edit cart
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://www.paypal.com/sdk/js?client-id=@Model.PayPalClientId&currency=@Model.CurrencyCode"></script>
    <script>
        paypal.Buttons({
            createOrder: function () {
                return fetch('/Checkout/CreatePayPalOrder', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    }
                })
                .then(function (res) { return res.json(); })
                .then(function (data) {
                    if (data.error) throw new Error(data.error);
                    return data.id;
                });
            },
            onApprove: function (data) {
                return fetch('/Checkout/CapturePayPalOrder', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ orderId: data.orderID })
                })
                .then(function (res) { return res.json(); })
                .then(function (result) {
                    if (result.success) {
                        window.location.href = '/Checkout/Success?orderId=' + result.orderId;
                    } else {
                        showError('Payment capture failed: ' + (result.error ?? 'Unknown error'));
                    }
                });
            },
            onCancel: function () {
                window.location.href = '/Checkout/Cancel';
            },
            onError: function (err) {
                showError('PayPal error: ' + err);
            }
        }).render('#paypal-button-container');

        function showError(msg) {
            var el = document.getElementById('paypal-error');
            el.textContent = msg;
            el.classList.remove('hidden');
        }
    </script>
}
