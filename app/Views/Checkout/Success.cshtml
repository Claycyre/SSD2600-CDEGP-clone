@model SSD2600_CDEGP.Models.Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="min-h-screen bg-gray-100 p-6">
    <div class="max-w-3xl mx-auto">
        <div class="bg-white rounded-2xl shadow p-8 text-center mb-6">
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-900 mb-2">Order Confirmed!</h1>
            <p class="text-gray-500 text-sm">Thank you for your purchase. Your order has been received.</p>
            <div class="mt-4 inline-block bg-gray-100 rounded-xl px-6 py-3">
                <p class="text-xs text-gray-500 uppercase tracking-wide">Order Number</p>
                <p class="font-mono font-bold text-blue-900 text-lg">@Model.OrderNumber</p>
            </div>
            @if (Model.Transaction != null)
            {
                <div class="mt-3 inline-block bg-gray-100 rounded-xl px-6 py-3 ml-2">
                    <p class="text-xs text-gray-500 uppercase tracking-wide">Transaction ID</p>
                    <p class="font-mono text-sm text-gray-700">@Model.Transaction.GatewayTransactionId</p>
                </div>
            }
        </div>

        <!-- Order Items -->
        <div class="bg-white rounded-2xl shadow p-6 mb-6">
            <h2 class="text-lg font-semibold mb-4">Items Ordered</h2>
            <div class="space-y-3">
                @foreach (var item in Model.OrderLineItems)
                {
                    <div class="flex justify-between items-center text-sm border-b border-gray-100 pb-3">
                        <div>
                            <p class="font-medium">@(item.Product?.Name ?? "Product")</p>
                            <p class="text-gray-400">Qty: @item.Quantity &times; @item.UnitPrice.ToString("C")</p>
                        </div>
                        <span class="font-semibold">@((item.Quantity * item.UnitPrice).ToString("C"))</span>
                    </div>
                }
            </div>
            @if (Model.Transaction != null)
            {
                <div class="flex justify-between font-bold text-base mt-4 pt-2">
                    <span>Total Paid</span>
                    <span>@Model.Transaction.Total.ToString("C") @Model.Transaction.CurrencyCode</span>
                </div>
            }
        </div>

        <div class="flex justify-center gap-4">
            <a asp-controller="Orders" asp-action="Index"
               class="bg-blue-600 text-white px-6 py-2 rounded-full hover:bg-blue-700 text-sm">
                View My Orders
            </a>
            <a asp-controller="ProductCatalogue" asp-action="Index"
               class="bg-gray-200 text-gray-700 px-6 py-2 rounded-full hover:bg-gray-300 text-sm">
                Continue Shopping
            </a>
        </div>
    </div>
</div>
