@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="min-h-screen bg-gray-100 p-6">
    <div class="mb-6">
        <img src="~/images/banner.jpg" alt="Banner" class="w-full rounded-2xl shadow-md" />
    </div>
    <h1 class="text-3xl font-bold text-center text-blue-900 mb-8">
        Shopping Cart
    </h1>
    <div class="flex max-w-6xl mx-auto gap-6">
        <div class="flex-1 flex flex-col space-y-2">
            <div class="relative flex items-center bg-white rounded-2xl shadow hover:shadow-lg transition duration-300 p-4">
                <button class="absolute top-2 right-2 w-6 h-6 flex items-center justify-center bg-gray-200 rounded-full text-gray-700 hover:bg-red-600 hover:text-white">
                    &times;
                </button>
                <img src="~/images/book.jpg" alt="Book" class="w-20 h-20 object-cover rounded-full mr-4">
                <div class="flex-1 text-center">
                    <h2 class="font-semibold text-lg">Book</h2>
                    <p class="text-gray-600 text-sm">A placeholder description of the book goes here.</p>
                </div>
                <div class="text-right flex flex-col items-end space-y-1">
                    <span class="font-semibold">$10.00</span>
                    <span>Qty: 1</span>
                </div>
            </div>
            <div class="relative flex items-center bg-white rounded-2xl shadow hover:shadow-lg transition duration-300 p-4">
                <button class="absolute top-2 right-2 w-6 h-6 flex items-center justify-center bg-gray-200 rounded-full text-gray-700 hover:bg-red-600 hover:text-white">
                    &times;
                </button>
                <img src="~/images/pen.jpg" alt="Pen" class="w-20 h-20 object-cover rounded-full mr-4">
                <div class="flex-1 text-center">
                    <h2 class="font-semibold text-lg">Pen</h2>
                    <p class="text-gray-600 text-sm">A placeholder description of the pen goes here.</p>
                </div>
                <div class="text-right flex flex-col items-end space-y-1">
                    <span class="font-semibold">$2.00</span>
                    <span>Qty: 3</span>
                </div>
            </div>
            <div class="relative flex items-center bg-white rounded-2xl shadow hover:shadow-lg transition duration-300 p-4">
                <button class="absolute top-2 right-2 w-6 h-6 flex items-center justify-center bg-gray-200 rounded-full text-gray-700 hover:bg-red-600 hover:text-white">
                    &times;
                </button>
                <img src="~/images/notebook.jpg" alt="Notebook" class="w-20 h-20 object-cover rounded-full mr-4">
                <div class="flex-1 text-center">
                    <h2 class="font-semibold text-lg">Notebook</h2>
                    <p class="text-gray-600 text-sm">A placeholder description of the notebook goes here.</p>
                </div>
                <div class="text-right flex flex-col items-end space-y-1">
                    <span class="font-semibold">$5.00</span>
                    <span>Qty: 2</span>
                </div>
            </div>
            <div class="flex justify-end space-x-0 mt-4">
                <button class="bg-blue-600 text-white px-6 py-2 rounded-l-full hover:bg-blue-700 text-sm">
                    Checkout
                </button>
                <button class="bg-red-600 text-white px-6 py-2 rounded-r-full hover:bg-red-700 text-sm">
                    Continue Shopping
                </button>
            </div>
        </div>
        <div class="w-64 bg-white rounded-2xl shadow p-4 flex flex-col justify-between">
            <h2 class="font-semibold text-lg mb-4 text-center">Order Summary</h2>
            <div class="flex justify-between mb-2">
                <span>Subtotal:</span>
                <span>$27.00</span>
            </div>
            <div class="flex justify-between mb-2">
                <span>Taxes:</span>
                <span>$2.16</span>
            </div>
            <div class="flex justify-between mb-2">
                <span>Shipping:</span>
                <span>$5.00</span>
            </div>
            <div class="border-t border-gray-300 mt-2 pt-2 font-bold flex justify-between">
                <span>Total:</span>
                <span>$34.16</span>
            </div>
        </div>
    </div>
    <div class="max-w-6xl mx-auto mt-8 relative">
        <button class="absolute left-0 top-1/2 transform -translate-y-1/2 bg-gray-200 hover:bg-gray-300 p-6 rounded-full z-10 text-3xl font-bold">
            &#8592;
        </button>

        <div class="overflow-x-auto flex space-x-6 snap-x snap-mandatory scrollbar-hide px-4">
            <div class="w-48 h-48 bg-gray-200 rounded-2xl flex-shrink-0 snap-center flex items-center justify-center p-4">
                <img src="~/images/book.jpg" class="object-cover w-full h-full rounded-2xl">
            </div>
            <div class="w-48 h-48 bg-gray-200 rounded-2xl flex-shrink-0 snap-center flex items-center justify-center p-4">
                <img src="~/images/pen.jpg" class="object-cover w-full h-full rounded-2xl">
            </div>
            <div class="w-48 h-48 bg-gray-200 rounded-2xl flex-shrink-0 snap-center flex items-center justify-center p-4">
                <img src="~/images/notebook.jpg" class="object-cover w-full h-full rounded-2xl">
            </div>
            <div class="w-48 h-48 bg-gray-200 rounded-2xl flex-shrink-0 snap-center flex items-center justify-center p-4">
                <img src="~/images/eraser.jpg" class="object-cover w-full h-full rounded-2xl">
            </div>
        </div>
        <button class="absolute right-0 top-1/2 transform -translate-y-1/2 bg-gray-200 hover:bg-gray-300 p-6 rounded-full z-10 text-3xl font-bold">
            &#8594;
        </button>
    </div>
</div>

