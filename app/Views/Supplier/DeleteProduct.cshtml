@model SSD2600_CDEGP.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="mx-auto w-full min-h-[calc(100vh-var(--header-height))] px-6 py-10 lg:px-10">
    <div class="mx-auto w-full max-w-xl space-y-6">

        <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Supplier</p>
            <h1 class="font-displayxp text-3xl text-primary-900">Delete Product</h1>
            <p class="text-sm text-neutral-600">This action cannot be undone.</p>
        </div>

        <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800">
            Are you sure you want to permanently delete <strong>@Model.Name</strong>? This action cannot be undone.
        </div>

        <dl class="space-y-2 text-sm">
            <div class="flex gap-4">
                <dt class="w-32 text-neutral-500">Name</dt>
                <dd class="text-neutral-900">@Model.Name</dd>
            </div>
            <div class="flex gap-4">
                <dt class="w-32 text-neutral-500">Type</dt>
                <dd class="text-neutral-900">@Model.ProductType</dd>
            </div>
            <div class="flex gap-4">
                <dt class="w-32 text-neutral-500">Price</dt>
                <dd class="text-neutral-900">@Model.UnitPrice.ToString("C")</dd>
            </div>
        </dl>

        <form asp-action="DeleteProduct" asp-route-id="@Model.PkSKU" method="post" class="flex flex-wrap gap-3">
            @Html.AntiForgeryToken()
            <PaButton
                tag="button"
                Attributes="type=submit"
                Theme="PaButtonTagHelper.Themes.Danger"
                Style="PaButtonTagHelper.Styles.Fill"
                Size="PaButtonTagHelper.Sizes.Base"
                Classes="">
                Confirm Delete
            </PaButton>
            <PaButton asp-action="Index" Style="PaButtonTagHelper.Styles.Outline"
                      Size="PaButtonTagHelper.Sizes.Base">
                Cancel
            </PaButton>
        </form>
    </div>
</div>
