@model SSD2600_CDEGP.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10 max-w-xl mx-auto">

            <h1 class="text-3xl font-semibold mb-6">Delete Product</h1>

            <div class="mb-6 border border-red-300 bg-red-50 text-red-800 px-4 py-3 rounded-lg">
                Are you sure you want to permanently delete <strong>@Model.Name</strong>? This action cannot be undone.
            </div>

            <dl class="mb-6 space-y-2 text-sm">
                <div class="flex gap-4">
                    <dt class="w-32 text-gray-500">Name</dt>
                    <dd>@Model.Name</dd>
                </div>
                <div class="flex gap-4">
                    <dt class="w-32 text-gray-500">Type</dt>
                    <dd>@Model.ProductType</dd>
                </div>
                <div class="flex gap-4">
                    <dt class="w-32 text-gray-500">Price</dt>
                    <dd>@Model.UnitPrice.ToString("C")</dd>
                </div>
            </dl>

            <form asp-action="DeleteProduct" asp-route-id="@Model.PkSKU" method="post">
                @Html.AntiForgeryToken()
                <div class="flex gap-4">
                    <button type="submit"
                            class="px-6 py-3 bg-red-600 text-white font-semibold rounded-lg hover:bg-red-700 shadow transition-colors">
                        Confirm Delete
                    </button>
                    <a asp-action="Products"
                       class="px-6 py-3 bg-gray-200 rounded-lg hover:bg-gray-300 transition-colors">Cancel</a>
                </div>
            </form>

        </div>
    </div>
</div>
