@model IEnumerable<SSD2600_CDEGP.Models.Product>
@using SSD2600_CDEGP.Helpers
@{
    ViewData["Title"] = "Manage Products";
    var currencyCode = (ViewBag.CurrencyCode as string) ?? "CAD";
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10">

            <div class="flex items-center justify-between mb-8">
                <h1 class="text-3xl font-semibold">@ViewData["Title"]</h1>
                <a asp-action="CreateProduct"
                   class="px-5 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 shadow transition-colors">
                    + Add Product
                </a>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="mb-6 border border-green-400 bg-green-50 text-green-800 px-4 py-3 rounded-lg">
                    @TempData["Success"]
                </div>
            }

            @if (!Model.Any())
            {
                <p class="text-gray-500 text-center py-10">You have no products yet.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-100 text-gray-700 uppercase text-xs">
                                <th class="px-4 py-3 border-b">Name</th>
                                <th class="px-4 py-3 border-b">Type</th>
                                <th class="px-4 py-3 border-b">Price</th>
                                <th class="px-4 py-3 border-b">Stock</th>
                                <th class="px-4 py-3 border-b">Status</th>
                                <th class="px-4 py-3 border-b">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr class="border-b hover:bg-gray-50 transition-colors">
                                    <td class="px-4 py-3">
                                        <div class="font-medium">@product.Name</div>
                                        @if (!string.IsNullOrEmpty(product.ShortName))
                                        {
                                            <div class="text-gray-500 text-xs">@product.ShortName</div>
                                        }
                                    </td>
                                    <td class="px-4 py-3">@product.ProductType</td>
                                    <td class="px-4 py-3">@PriceUtils.Format(product.UnitPrice, currencyCode)</td>
                                    <td class="px-4 py-3">@product.StockQuantity</td>
                                    <td class="px-4 py-3">
                                        @if (product.IsAdminVerified)
                                        {
                                            <span class="text-green-600 font-semibold">&#10003; Verified</span>
                                        }
                                        else
                                        {
                                            <span class="text-yellow-600 font-semibold">&#9888; Pending Verification</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3">
                                        <div class="flex gap-2">
                                            <a asp-action="EditProduct" asp-route-id="@product.PkSKU"
                                               class="text-xs px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700 transition-colors">Edit</a>
                                            <a asp-action="DeleteProduct" asp-route-id="@product.PkSKU"
                                               class="text-xs px-3 py-1 bg-red-600 text-white rounded hover:bg-red-700 transition-colors">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>
