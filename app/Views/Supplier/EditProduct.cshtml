@model Product

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container">
    <h1>Edit Product: @Model.Name</h1>

    <form method="post" asp-action="EditProduct">
        <input type="hidden" asp-for="PkSKU" />
        <input type="hidden" asp-for="StockQuantity" />
        <input type="hidden" asp-for="FkSupplierId" />

        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" readonly />
        </div>

        <div class="form-group">
            <label asp-for="Description" class="control-label"></label>
            <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" asp-route-id="@Model.FkSupplierId" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
