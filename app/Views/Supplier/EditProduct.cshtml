@model SSD2600_CDEGP.Models.ProductAddOrEditViewModel
@{
    ViewData["Title"] = "Edit Product";
}

<div class="mx-auto w-full min-h-[calc(100vh-var(--header-height))] px-6 py-10 lg:px-10">
    <div class="mx-auto w-full max-w-2xl space-y-6">

        <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Supplier</p>
            <h1 class="font-displayxp text-3xl text-primary-900">Edit Product</h1>
            <p class="text-sm text-neutral-600">Update listing details for review.</p>
        </div>

        <p class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-800">
            &#9888; Saving changes will require admin re-verification before the updated product appears in the
            catalogue.
        </p>

        <form asp-action="EditProduct" asp-route-id="@ViewBag.ProductId" method="post" class="space-y-6">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800"></div>

            @await Html.PartialAsync("_ProductFormFields", Model)

            <div class="flex flex-wrap gap-3">
                <PaButton tag="button" Attributes="type=submit" Theme="PaButton.Themes.Primary"
                          Style="PaButton.Styles.Fill" Size="PaButton.Sizes.Base"
                          Classes="inline-flex items-center justify-center text-sm font-semibold shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40">
                    Save &amp; Submit for Re-Verification
                </PaButton>
                <PaButton asp-action="Index" Style="PaButton.Styles.Outline"
                          Size="PaButton.Sizes.Base">
                    Cancel
                </PaButton>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
