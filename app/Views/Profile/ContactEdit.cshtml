@model SSD2600_CDEGP.Models.ContactDetail

@{
    ViewData["Title"] = "Edit Contact Details";
}

<div class="min-h-screen bg-gray-100">

    <div class="bg-blue-900 text-white text-center py-6 shadow">
        <h1 class="text-3xl font-bold">Edit Contact Details</h1>
        <div class="mt-4">
            <img src="~/images/banner.jpg" alt="Banner"
                 class="mx-auto h-24 object-cover rounded shadow">
        </div>
    </div>

    <div class="max-w-4xl mx-auto p-8">
        <div class="bg-white rounded shadow p-8">

            <h2 class="text-xl font-semibold mb-6 text-center">Update Your Information</h2>

            <form asp-action="ContactEdit" method="post" class="space-y-4">

                <input type="hidden" asp-for="PkContactId" />

                <div>
                    <label class="block text-sm font-medium mb-1">First Name</label>
                    <input asp-for="NameFirst"
                           class="w-full border p-2 rounded bg-gray-50 focus:bg-white" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Last Name</label>
                    <input asp-for="NameFirst"
                           class="w-full border p-2 rounded bg-gray-50 focus:bg-white" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Email Address</label>
                    <input asp-for="EmailAddress"
                           class="w-full border p-2 rounded bg-gray-50 focus:bg-white" />
                </div>

                <div>
                    <label class="block text-sm font-medium mb-1">Phone Number</label>
                    <input asp-for="PhoneNumber"
                           class="w-full border p-2 rounded bg-gray-50 focus:bg-white" />
                </div>

                <div class="flex flex-col items-center mt-8">
                    <button type="submit"
                            class="bg-blue-600 text-white px-6 py-2 rounded-t hover:bg-blue-700">
                        Save Changes
                    </button>

                    <a asp-action="ContactIndex"
                       class="bg-red-600 text-white px-6 py-2 rounded-b hover:bg-red-700 text-center w-full">
                        Cancel
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>
