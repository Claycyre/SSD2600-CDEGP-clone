@model SSD2600_CDEGP.Models.ContactDetail

@{
    ViewData["Title"] = "Contact Details";
}

<div class="min-h-screen bg-gray-100">

    <div class="bg-blue-900 text-white text-center py-6 shadow">
        <h1 class="text-3xl font-bold">Contact Details</h1>

        <div class="mt-4">
            <img src="~/images/banner.jpg" alt="Banner"
                 class="mx-auto h-24 object-cover rounded shadow">
        </div>
    </div>

    <div class="max-w-4xl mx-auto p-8">
        <div class="bg-white rounded shadow p-8">

            <h2 class="text-xl font-semibold mb-6 text-center">View Contact Information</h2>

            <div class="space-y-4 text-sm">

                <div>
                    <strong>First Name:</strong> @Model.NameFirst
                </div>
                <div>
                    <strong>Last Name:</strong> @Model.NameLast
                </div>

                <div>
                    <strong>Email:</strong> @Model.EmailAddress
                </div>

                <div>
                    <strong>Phone:</strong> @Model.PhoneNumber
                </div>

            </div>

            <div class="flex justify-between mt-8">

                <a asp-action="ContactIndex"
                   class="bg-gray-200 text-gray-700 px-4 py-2 rounded hover:bg-gray-300">
                    Back
                </a>

                <div class="space-x-2">
                    <a asp-action="ContactEdit" asp-route-id="@Model.PkContactId"
                       class="bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600">
                        Edit
                    </a>

                    <a asp-action="ContactDelete" asp-route-id="@Model.PkContactId"
                       class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">
                        Delete
                    </a>
                </div>

            </div>

        </div>
    </div>

</div>

