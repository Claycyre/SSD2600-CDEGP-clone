@model IEnumerable<SSD2600_CDEGP.Models.ContactDetail>

@{
    ViewData["Title"] = "Contact Records";
}

<div class="min-h-screen bg-gray-100">

    <div class="bg-blue-900 text-white text-center py-6 shadow">
        <h1 class="text-3xl font-bold">Contact Records</h1>

        <div class="mt-4">
            <img src="~/images/banner.jpg" alt="Banner"
                 class="mx-auto h-24 object-cover rounded shadow">
        </div>
    </div>

    <div class="max-w-5xl mx-auto p-8">
        <div class="bg-white rounded shadow p-6">

            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-semibold">Saved Contacts</h2>

                <a asp-action="ContactCreate"
                   class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 text-sm">
                    + Create New
                </a>
            </div>

            <table class="w-full text-sm border">
                <thead class="bg-gray-50 border-b">
                    <tr>
                        <th class="p-3 text-left">First Name</th>
                        <th class="p-3 text-left">Last Name</th>
                        <th class="p-3 text-left">Email Address</th>
                        <th class="p-3 text-left">Phone Number</th>
                        <th class="p-3 text-right">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="border-b">
                            <td class="p-3">@item.NameFirst</td>
                            <td class="p-3">@item.NameLast</td>
                            <td class="p-3">@item.EmailAddress</td>
                            <td class="p-3">@item.PhoneNumber</td>
                            <td class="p-3 text-right space-x-2">
                                <a asp-action="ContactDetails" asp-route-id="@item.PkContactId"
                                   class="px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700">
                                    View
                                </a>

                                <a asp-action="ContactEdit" asp-route-id="@item.PkContactId"
                                   class="px-3 py-1 bg-yellow-500 text-white rounded hover:bg-yellow-600">
                                    Edit
                                </a>

                                <a asp-action="ContactDelete" asp-route-id="@item.PkContactId"
                                   class="px-3 py-1 bg-red-600 text-white rounded hover:bg-red-700">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>
