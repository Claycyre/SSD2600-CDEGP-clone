@model IEnumerable<SSD2600_CDEGP.Models.AdminMessage>
@{
    ViewData["Title"] = "Inbox";
    var unread = Model.Count(m => !m.IsRead);
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10">

            <div class="flex items-center justify-between mb-8">
                <div>
                    <h1 class="text-3xl font-semibold">Inbox</h1>
                    @if (unread > 0)
                    {
                        <p class="text-sm text-amber-600 mt-1">
                            @unread unread message@(unread == 1 ? "" : "s")
                        </p>
                    }
                </div>
            </div>

            @if (!Model.Any())
            {
                <p class="text-gray-500 text-center py-10">Your inbox is empty.</p>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-100 text-gray-700 uppercase text-xs">
                                <th class="px-2 py-3 border-b w-4"></th>
                                <th class="px-4 py-3 border-b">Subject</th>
                                <th class="px-4 py-3 border-b">From</th>
                                <th class="px-4 py-3 border-b">Received</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var msg in Model)
                            {
                                <tr class="border-b hover:bg-gray-50 transition-colors @(msg.IsRead ? "" : "bg-blue-50")"
                                    onclick="location.href='@Url.Action("Read", new { id = msg.Id })'"
                                    style="cursor:pointer">
                                    <td class="px-2 py-3 text-center">
                                        @if (!msg.IsRead)
                                        {
                                            <span class="inline-block w-2 h-2 rounded-full bg-blue-500"
                                                  title="Unread"></span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 @(msg.IsRead ? "" : "font-semibold")">@msg.Subject</td>
                                    <td class="px-4 py-3 text-gray-600">@(msg.Sender.UserName ?? msg.Sender.Email ?? "—")</td>
                                    <td class="px-4 py-3 text-gray-500">@msg.SentAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>
