@model SSD2600_CDEGP.Models.AdminMessage
@{
    ViewData["Title"] = Model.Subject;
}

<div class="min-h-screen bg-gray-100">
    <div class="w-full px-10 py-10">
        <div class="bg-white rounded-2xl shadow-2xl p-10 max-w-3xl mx-auto">

            <a asp-action="Index" class="text-sm text-slate-600 hover:underline">&#8592; Inbox</a>

            <h1 class="text-2xl font-semibold mt-6 mb-2">@Model.Subject</h1>

            <div class="flex flex-wrap gap-6 text-sm text-gray-500 mb-8 border-b pb-6">
                <span>
                    <strong class="text-gray-700">From:</strong>
                    @(Model.Sender.UserName ?? Model.Sender.Email ?? "—")
                </span>
                <span>
                    <strong class="text-gray-700">Sent:</strong>
                    @Model.SentAt.ToString("yyyy-MM-dd HH:mm") UTC
                </span>
            </div>

            <div class="text-sm text-gray-800 leading-relaxed whitespace-pre-wrap">@Model.Body</div>

        </div>
    </div>
</div>
