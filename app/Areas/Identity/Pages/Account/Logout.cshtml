@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="min-h-[calc(100vh-var(--header-height))] bg-neutral-50 px-4 py-10 sm:px-6 lg:px-10">
    <div class="mx-auto w-full max-w-xl">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-xl shadow-primary-900/10 sm:p-8">
            <div class="space-y-3">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Account</p>
                <h1 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h1>
                @{
                    if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                            <PaButton
                                tag="button"
                                Attributes="type=submit"
                                Theme="PaButton.Themes.None"
                                Style="PaButton.Styles.Outline"
                                Size="PaButton.Sizes.Base"
                                Classes="inline-flex items-center justify-center text-sm font-semibold bg-white shadow-sm">
                                Confirm logout
                            </PaButton>
                        </form>
                    }
                    else
                    {
                        <p class="text-sm text-neutral-600">You have successfully logged out of the application.</p>
                    }
                }
            </div>
        </div>
    </div>
</div>
