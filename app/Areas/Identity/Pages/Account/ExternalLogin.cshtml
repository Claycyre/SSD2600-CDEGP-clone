@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Register";
}

<div class="min-h-[calc(100vh-var(--header-height))] bg-neutral-50 px-4 py-10 sm:px-6 lg:px-10">
    <div class="mx-auto w-full max-w-2xl">
        <div class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-xl shadow-primary-900/10 sm:p-8">
            <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Account</p>
                <h1 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h1>
                <p id="external-login-title" class="text-sm font-semibold text-neutral-700">Associate your @Model.ProviderDisplayName account.</p>
            </div>
            <p id="external-login-description" class="mt-4 text-sm text-neutral-600">
                You've successfully authenticated with <strong>@Model.ProviderDisplayName</strong>.
                Please enter an email address for this site below and click Register to finish logging in.
            </p>
            <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mt-6 space-y-5">
                <div asp-validation-summary="ModelOnly" class="rounded-lg border border-beta-200 bg-beta-50 px-3 py-2 text-sm text-beta-800" role="alert"></div>
                <div class="space-y-2">
                    <label asp-for="Input.Email" class="text-sm font-semibold text-neutral-700">Email</label>
                    <input asp-for="Input.Email" class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30" autocomplete="email" placeholder="Please enter your email." />
                    <span asp-validation-for="Input.Email" class="text-sm text-beta-600"></span>
                </div>
                <PaButton
                    tag="button"
                    Attributes="type=submit"
                    Theme="PaButtonTagHelper.Themes.Primary"
                    Style="PaButtonTagHelper.Styles.Fill"
                    Size="PaButtonTagHelper.Sizes.Base"
                    Classes="inline-flex w-full items-center justify-center text-sm font-semibold shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40">
                    Register
                </PaButton>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
