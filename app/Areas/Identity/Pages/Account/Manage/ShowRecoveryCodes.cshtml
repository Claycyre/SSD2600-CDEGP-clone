@page
@model ShowRecoveryCodesModel
@{
    ViewData["Title"] = "Recovery codes";
    ViewData["ActivePage"] = "TwoFactorAuthentication";
}

<div class="space-y-2">
    <h2 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h2>
    <p class="text-sm text-neutral-600">Store these codes securely. Each code can be used once.</p>
</div>
<div class="mt-4">
    <partial name="_StatusMessage" for="StatusMessage" />
</div>
<div class="mt-4 rounded-xl border border-secondary-200 bg-secondary-50 px-4 py-3 text-sm text-secondary-900" role="alert">
    <p class="font-semibold">Put these codes in a safe place.</p>
    <p class="mt-1">If you lose your device and don't have the recovery codes you will lose access to your account.</p>
</div>
<div class="mt-4 grid gap-2 sm:grid-cols-2">
    @for (var row = 0; row < Model.RecoveryCodes.Length; row += 2)
    {
        <code class="rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 font-mono text-xs text-neutral-800">@Model.RecoveryCodes[row]</code>
        <code class="rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 font-mono text-xs text-neutral-800">@Model.RecoveryCodes[row + 1]</code>
    }
</div>
