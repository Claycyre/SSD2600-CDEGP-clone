@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout) && parentLayout !=  null)
    {
        Layout = parentLayout.ToString();
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="min-h-[calc(100vh-var(--header-height))] px-4 py-10 sm:px-6 lg:px-10">
    <div class="mx-auto w-full max-w-6xl">
        <div class="space-y-2">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-neutral-500">Account</p>
            <h1 class="font-displayxp text-3xl text-primary-900">Manage your account</h1>
            <p class="text-sm text-neutral-600">Update your profile, security, and data settings.</p>
        </div>
        <div class="mt-8 grid gap-6 lg:grid-cols-[16rem_minmax(0,1fr)]">
            <aside class="rounded-2xl border border-neutral-200 bg-white p-4 shadow-sm">
                <partial name="_ManageNav" />
            </aside>
            <section class="rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm sm:p-8">
                @RenderBody()
            </section>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}
