@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="space-y-2">
    <h2 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h2>
    <p class="text-sm text-neutral-600">Download or delete the data associated with your account.</p>
</div>
<div class="mt-4 space-y-4 text-sm text-neutral-700">
    <p>Your account contains personal data that you have given us. This page allows you to download or delete that data.</p>
    <p class="rounded-xl border border-secondary-200 bg-secondary-50 px-4 py-3 text-secondary-900">
        <strong>Deleting this data will permanently remove your account, and this cannot be recovered.</strong>
    </p>
    <div class="flex flex-wrap gap-3">
        <form id="download-data" asp-page="DownloadPersonalData" method="post">
            <PaButton
                tag="button"
                Attributes="type=submit"
                Theme="PaButtonTagHelper.Themes.None"
                Style="PaButtonTagHelper.Styles.Outline"
                Size="PaButtonTagHelper.Sizes.Base"
                Classes="inline-flex items-center justify-center text-sm font-semibold bg-white shadow-sm hover:border-neutral-400">
                Download
            </PaButton>
        </form>
        <a id="delete" asp-page="DeletePersonalData" class="inline-flex items-center justify-center rounded-md bg-beta-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-beta-700">Delete</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
