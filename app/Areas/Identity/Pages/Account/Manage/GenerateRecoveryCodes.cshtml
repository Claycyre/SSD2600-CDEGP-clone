@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Generate two-factor authentication (2FA) recovery codes";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<div class="space-y-2">
    <h2 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h2>
    <p class="text-sm text-neutral-600">Generate a fresh set of codes for emergency access.</p>
</div>
<div class="mt-4">
    <partial name="_StatusMessage" for="StatusMessage" />
</div>
<div class="mt-4 rounded-xl border border-secondary-200 bg-secondary-50 px-4 py-3 text-sm text-secondary-900" role="alert">
    <p class="font-semibold">Put these codes in a safe place.</p>
    <p class="mt-1">
        If you lose your device and don't have the recovery codes you will lose access to your account.
    </p>
    <p class="mt-1">
        Generating new recovery codes does not change the keys used in authenticator apps. If you wish to change the key
        used in an authenticator app you should
        <a class="font-semibold text-primary-700 hover:text-primary-600" asp-page="./ResetAuthenticator">reset your authenticator keys</a>.
    </p>
</div>
<form method="post" class="mt-4">
    <button class="inline-flex items-center justify-center rounded-md bg-beta-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-beta-700" type="submit">Generate recovery codes</button>
</form>
