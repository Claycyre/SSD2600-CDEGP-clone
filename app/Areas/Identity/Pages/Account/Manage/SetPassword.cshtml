@page
@model SetPasswordModel
@{
    ViewData["Title"] = "Set password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="space-y-2">
    <h2 class="font-displayxp text-2xl text-primary-900">Set your password</h2>
    <p class="text-sm text-neutral-600">
        You do not have a local username/password for this site. Add a local
        account so you can log in without an external login.
    </p>
</div>
<div class="mt-4">
    <partial name="_StatusMessage" for="StatusMessage" />
</div>
<form id="set-password-form" method="post" class="mt-6 space-y-5 max-w-xl">
    <div asp-validation-summary="ModelOnly" class="rounded-lg border border-beta-200 bg-beta-50 px-3 py-2 text-sm text-beta-800" role="alert"></div>
    <div class="space-y-2">
        <label asp-for="Input.NewPassword" class="text-sm font-semibold text-neutral-700"></label>
        <input asp-for="Input.NewPassword" class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30" autocomplete="new-password" placeholder="Please enter your new password." />
        <span asp-validation-for="Input.NewPassword" class="text-sm text-beta-600"></span>
    </div>
    <div class="space-y-2">
        <label asp-for="Input.ConfirmPassword" class="text-sm font-semibold text-neutral-700"></label>
        <input asp-for="Input.ConfirmPassword" class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30" autocomplete="new-password" placeholder="Please confirm your new password." />
        <span asp-validation-for="Input.ConfirmPassword" class="text-sm text-beta-600"></span>
    </div>
    <PaButton
        tag="button"
        Attributes="type=submit"
        Theme="PaButtonTagHelper.Themes.Primary"
        Style="PaButtonTagHelper.Styles.Fill"
        Size="PaButtonTagHelper.Sizes.Base"
        Classes="inline-flex items-center justify-center text-sm font-semibold shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500/40">
        Set password
    </PaButton>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
