@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Delete Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="space-y-2">
    <h2 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h2>
    <p class="text-sm text-neutral-600">This action permanently removes your account.</p>
</div>

<div class="mt-4 rounded-xl border border-secondary-200 bg-secondary-50 px-4 py-3 text-sm text-secondary-900" role="alert">
    <p class="font-semibold">Deleting this data will permanently remove your account, and this cannot be recovered.</p>
</div>

<form id="delete-user" method="post" class="mt-6 space-y-5 max-w-xl">
    <div asp-validation-summary="ModelOnly" class="rounded-lg border border-beta-200 bg-beta-50 px-3 py-2 text-sm text-beta-800" role="alert"></div>
    @if (Model.RequirePassword)
    {
        <div class="space-y-2">
            <label asp-for="Input.Password" class="text-sm font-semibold text-neutral-700"></label>
            <input asp-for="Input.Password" class="w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm placeholder:text-neutral-400 focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30" autocomplete="current-password" aria-required="true" placeholder="Please enter your password." />
            <span asp-validation-for="Input.Password" class="text-sm text-beta-600"></span>
        </div>
    }
    <PaButton
        tag="button"
        Attributes="type=submit"
        Theme="PaButton.Themes.Danger"
        Style="PaButton.Styles.Fill"
        Size="PaButton.Sizes.Base"
        Classes="inline-flex w-full items-center justify-center text-sm font-semibold shadow-sm">
        Delete data and close my account
    </PaButton>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
