@page
@model ExternalLoginsModel
@{
    ViewData["Title"] = "Manage your external logins";
    ViewData["ActivePage"] = ManageNavPages.ExternalLogins;
}

<div class="space-y-2">
    <h2 class="font-displayxp text-2xl text-primary-900">@ViewData["Title"]</h2>
    <p class="text-sm text-neutral-600">Connect or remove sign-in providers for your account.</p>
</div>
<div class="mt-4">
    <partial name="_StatusMessage" for="StatusMessage" />
</div>
@if (Model.CurrentLogins?.Count > 0)
{
    <div class="mt-6 space-y-2">
        <h3 class="text-lg font-semibold text-neutral-800">Registered logins</h3>
        <p class="text-sm text-neutral-600">Manage external providers linked to your account.</p>
    </div>
    <div class="mt-4 overflow-hidden rounded-xl border border-neutral-200">
        <table class="w-full text-left text-sm text-neutral-700">
            <tbody class="divide-y divide-neutral-200">
                @foreach (var login in Model.CurrentLogins)
                {
                    <tr class="bg-white">
                        <td class="px-4 py-3 font-semibold" id="@($"login-provider-{login.LoginProvider}")">@login.ProviderDisplayName</td>
                        <td class="px-4 py-3 text-right">
                            @if (Model.ShowRemoveButton)
                            {
                                <form id="@($"remove-login-{login.LoginProvider}")" asp-page-handler="RemoveLogin" method="post">
                                    <div>
                                        <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                        <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                        <PaButton
                                            tag="button"
                                            Attributes="type=submit title='Remove this @login.ProviderDisplayName login from your account'"
                                            Theme="PaButtonTagHelper.Themes.Danger"
                                            Style="PaButtonTagHelper.Styles.Fill"
                                            Size="PaButtonTagHelper.Sizes.Small"
                                            Classes="inline-flex items-center justify-center text-xs py-1.5 shadow-sm">
                                            Remove
                                        </PaButton>
                                    </div>
                                </form>
                            }
                            else
                            {
                                @: &nbsp;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
@if (Model.OtherLogins?.Count > 0)
{
    <div class="mt-8 space-y-2">
        <h3 class="text-lg font-semibold text-neutral-800">Add another service to log in</h3>
        <p class="text-sm text-neutral-600">Link a new provider to streamline future sign-ins.</p>
    </div>
    <form id="link-login-form" asp-page-handler="LinkLogin" method="post" class="mt-4">
        <div id="socialLoginList" class="flex flex-wrap gap-3">
            @foreach (var provider in Model.OtherLogins)
            {
                <PaButton
                    tag="button"
                    Attributes="type=submit id=link-login-button-{provider.Name} name=provider value={provider.Name} title='Log in using your {provider.DisplayName} account'"
                    Theme="PaButtonTagHelper.Themes.None"
                    Style="PaButtonTagHelper.Styles.Outline"
                    Size="PaButtonTagHelper.Sizes.Base"
                    Classes="inline-flex items-center justify-center text-sm font-semibold bg-white shadow-sm hover:border-neutral-400">
                    @provider.DisplayName
                </PaButton>
            }
        </div>
    </form>
}
