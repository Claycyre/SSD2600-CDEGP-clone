@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Register confirmation";
}

<div class="min-h-screen bg-gray-100 flex items-center justify-center py-12 px-4">
    <div class="bg-white rounded-2xl shadow-2xl p-10 max-w-md w-full text-center">

        <div class="text-5xl mb-4" aria-hidden="true">&#9993;</div>
        <h1 class="text-2xl font-semibold mb-3">Check your email</h1>
        <p class="text-gray-600 text-sm mb-8">
            We sent a confirmation link to <strong>@Model.Email</strong>.
            Click it to activate your account before signing in.
        </p>

        <a href="/Identity/Account/Login"
           class="inline-block text-sm text-slate-600 hover:underline mt-2">
            Back to login
        </a>

    </div>
</div>
