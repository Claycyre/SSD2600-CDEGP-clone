{
  "compilerOptions": {
    "noImplicitAny": false,
    "noEmitOnError": true,
    "removeComments": false,
    "sourceMap": true,
    "allowJs": true,
    "target": "ES6",
    "outDir": "wwwroot/dist/js"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "wwwroot"],
  "strict": true,
  "compileOnSave": true
}
